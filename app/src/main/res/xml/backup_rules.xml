<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- SQLCipher data cannot be restored without its device-bound Keystore key. -->
    <exclude domain="database" path="." />
    <exclude domain="device_database" path="." />

    <!-- Includes the wrapped database key and device-bound auth/security state. -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="device_sharedpref" path="." />
</full-backup-content>
