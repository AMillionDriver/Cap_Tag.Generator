<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="generate"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_generate"
        android:shortcutLongLabel="@string/shortcut_generate_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.axoloth.captaggenerator"
            android:targetClass="com.axoloth.captaggenerator.MainActivity">
            <extra android:name="shortcut_action" android:value="action_generate" />
        </intent>
    </shortcut>

    <shortcut
        android:shortcutId="history"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_history"
        android:shortcutLongLabel="@string/shortcut_history_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.axoloth.captaggenerator"
            android:targetClass="com.axoloth.captaggenerator.MainActivity">
            <extra android:name="shortcut_action" android:value="action_history" />
        </intent>
    </shortcut>
</shortcuts>
